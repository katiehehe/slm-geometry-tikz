# Copy to .env and fill in your values:  cp .env.example .env
# Config for the optional LLM-as-judge (src/geotikz/judge.py).
#
# Works with plain OpenAI or any OpenAI-compatible gateway (e.g. TrueFoundry).
# The scripts auto-load this file, so once .env exists you never export by hand.

# Gateway/endpoint. Leave unset to talk to OpenAI directly.
OPENAI_BASE_URL=https://<your-gateway-host>/api/inference/openai/v1

# Your key: an OpenAI key, or a TrueFoundry PAT/VAT for the gateway.
OPENAI_API_KEY=<your-api-key>

# Model id. For a gateway use the provider-qualified id (see the Playground),
# e.g. openai-group/gpt-4o  or  claude-group/claude-haiku-4-5.
JUDGE_MODEL=openai-group/gpt-4o
